      "name": "Submit a drug-pair prediction job",
      "request": {
        "name": "Submit a drug-pair prediction job",
        "description": {
          "content": "Submit a pair of drugs (as SMILES strings) for piscesCSM prediction. The response returns a unique job identifier used to poll for results.",
