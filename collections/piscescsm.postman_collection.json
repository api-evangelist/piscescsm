  "info": {
    "_postman_id": "fe1a3ffb-c5a8-44d4-b456-a7a4e5215e52",
    "name": "piscesCSM API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The piscesCSM API allows users to integrate piscesCSM drug-pair cancer sensitivity prediction into research pipelines. Submit a pair of small molecules as SMILES strings, then poll the prediction status using the returned job identifier. Results include predictions across multiple cancer types and molecular descriptors for both drugs.\n\nContact Support:\n Name: piscesCSM Support",
      "type": "text/plain"
    }
